{
  "permissions": {
    "allow": [
      "Bash(mvn:*)",
      "Bash(mvnw:*)",
      "Bash(java:*)",
      "Bash(javac:*)",
      "Bash(docker:*)",
      "Bash(mysql:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
